# App namespace for shared Cloudflare R2 storage
APP_SLUG=bkn-gigs
APP_ENV=prod

# Cloudflare R2 credentials
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=atl-gigs-data

# R2 object layout:
# apps/bkn-gigs/prod/public/events.json
# apps/bkn-gigs/prod/public/scrape-status.json
# apps/bkn-gigs/prod/state/seen-cache.json
# apps/bkn-gigs/prod/state/scrape-log.txt
# shared/artist-cache.json
# shared/artist-spotify-cache.json
R2_SHARE_ARTIST_CACHES=true

# Public R2 URLs
R2_PUBLIC_BUCKET_URL=https://pub-756023fa49674586a44105ba7bf52137.r2.dev
R2_PUBLIC_BASE_URL=https://pub-756023fa49674586a44105ba7bf52137.r2.dev/apps/bkn-gigs/prod/public

# Frontend/Vercel fetch URL. Keep this identical to R2_PUBLIC_BASE_URL.
VITE_R2_PUBLIC_BASE_URL=https://pub-756023fa49674586a44105ba7bf52137.r2.dev/apps/bkn-gigs/prod/public

# Spotify (for artist link enrichment)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
