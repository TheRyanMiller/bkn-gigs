APP_SLUG=bkn-gigs
APP_ENV=prod

# Shared physical bucket; all Brooklyn app data stays under apps/bkn-gigs/.
R2_BUCKET_NAME=atl-gigs-data
R2_ENDPOINT_URL=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_URL=https://pub-756023fa49674586a44105ba7bf52137.r2.dev

R2_KEY_PREFIX=apps/bkn-gigs/prod
R2_PUBLIC_PREFIX=apps/bkn-gigs/prod/public
R2_STATE_PREFIX=apps/bkn-gigs/prod/state
R2_SHARED_PREFIX=shared
R2_SHARE_ARTIST_CACHES=true

# Artist link enrichment. Keep the secret values local or in GitHub Actions secrets.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_SEARCH_LIMIT=100

VITE_R2_PUBLIC_URL=https://pub-756023fa49674586a44105ba7bf52137.r2.dev
VITE_R2_PUBLIC_PREFIX=apps/bkn-gigs/prod/public
